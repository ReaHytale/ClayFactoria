{
  "Type": "Abstract",
  "StartState": "Idle",
  "Parameters": {
    "Appearance": {
      "Value": "Trork_Clay",
      "Description": "Model to be used"
    },
    "ViewRange": {
      "Value": 15,
      "Description": "View range"
    },
    "DropList": {
      "Value": "Empty",
      "Description": "Drop Items"
    },
    "MaxSpeed": {
      "Value": 3,
      "Description": "Maximum walking speed"
    },
    "MaxHealth": {
      "Value": 100,
      "Description": "Max health for the NPC"
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Template.name",
      "Description": "Translation key for NPC name display"
    },
    "CanDoTake": {
      "Description": "Whether this automaton can perform the TAKE action",
      "TypeHint": "Boolean",
      "Value": false
    },
    "CanDoDeposit": {
      "Description": "Whether this automaton can perform the DEPOSIT action",
      "TypeHint": "Boolean",
      "Value": false
    },
    "CanDoPosition": {
      "Description": "Whether this automaton can perform the POSITION action",
      "TypeHint": "Boolean",
      "Value": true
    },
    "CanDoWork": {
      "Description": "Whether this automaton can perform the WORK action",
      "TypeHint": "Boolean",
      "Value": false
    }
  },
  "Appearance": { "Compute": "Appearance" },
  "DropList": { "Compute": "DropList" },
  "DisableDamageGroups": [ "Self" ],
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Neutral",
  "KnockbackScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": { "Compute": "MaxSpeed" },
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "MaxHealth": { "Compute": "MaxHealth" },
  "CombatConfig": {
    "EntityEffect": "Immunity_Environmental"
  },
  "StateTransitions": [
    {
      "$Comment": "Always clear target and reset instructions when going back to idle.",
      "States": [
        {
          "To": [ "Idle" ],
          "From": [ ]
        }
      ],
      "Actions": [
        {
          "Type": "ReleaseTarget"
        },
        {
          "Type": "ResetInstructions"
        },
        {
          "Type": "PlayAnimation",
          "Slot": "Status"
        },
        {
          "Type": "DropInventory"
        }
      ]
    },
    {
      "States": [
        {
          "From": [ ],
          "To": [ "Path" ]
        }
      ],
      "Actions": [
        {
          "Type": "PlayAnimation",
          "Slot": "Status",
          "Animation": "Walk"
        }
      ],
      "$Comment": "Play walking animation when pathing"
    }
  ],
  "Instructions": [
    {
      "$Comment": "Pathing, run all the time regardless of other instructions",
      "Continue": true,
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "And",
            "Sensors": [
              {
                "Type": "FlockLeader"
              },
              {
                "Type": "Self",
                "Filters": [
                  {
                    "Type": "Flock",
                    "FlockStatus": "Follower"
                  }
                ]
              }
            ]
          },
          "Actions": [
            {
              "Type": "Timeout",
              "Delay": [ 0.5, 2 ],
              "Action": {
                "Type": "SetLeashPosition",
                "ToTarget": true
              }
            }
          ]
        },
        {
          "$Comment": "Play Hold animation if holding an item right now",
          "Continue": true,
          "Sensor": {
            "Type": "Flag",
            "Name": "HoldingItem",
            "Set": true
          },
          "Actions": [
            {
              "Type": "PlayAnimation",
              "Slot": "Status",
              "Animation": "Hold",
              "Once": true
            }
          ]
        }
      ]
    },
    {
      "Instructions": [
        {
          "$Comment": "Await player instruction",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "HasAnyTasks"
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Path"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Player",
                "Range": 10,
                "Filters": [
                  {
                    "Type": "ItemInHand",
                    "Items": [ "Tool_Brush" ]
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Alerted"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Idle"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "Player nearby with brush in hand",
          "Sensor": {
            "$Comment": "Play Alerted Particle Effect. Look at player. Await Interaction. Timeout after 15, seconds",
            "Type": "State",
            "State": "Alerted"
          },
          "Instructions": [
            {
              "$Comment": "Animations",
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Alerted"
                },
                {
                  "Type": "SpawnParticles",
                  "Offset": [ 0, 1, 0 ],
                  "ParticleSystem": "Alerted"
                }
              ]
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": 10,
                "Filters": [
                  {
                    "Type": "ItemInHand",
                    "Items": [ "Tool_Brush" ]
                  }
                ]
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "$Comment": "Change back to idle once there is no longer a player in range",
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "$Comment": "Return to idle when item in hand is not brush",
                  "Type": "Player",
                  "Range": 10,
                  "Filters": [
                    {
                      "Type": "ItemInHand",
                      "Items": [ "Tool_Brush" ]
                    }
                  ]
                }
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "Interaction state - look at player while Interacting. Timeout at 15 seconds to go back to Idle",
          "Sensor": {
            "Type": "State",
            "State": "$Interaction"
          },
          "Instructions": [
            {
              "$Comment": "Return to idle when item in hand is not brush",
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Player",
                  "Range": { "Compute": "ViewRange" },
                  "Filters": [
                    {
                      "Type": "ItemInHand",
                      "Items": [ "Tool_Brush" ]
                    }
                  ]
                }
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            },
            {
              "Sensor": {
                "$Comment": "Initially gets us into the pathing state",
                "Type": "LeashTarget"
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Path"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "Pathing state - Path to a single point or line path",
          "Sensor": {
            "Type": "State",
            "State": "Path"
          },
          "Instructions": [
            {
              "Continue": true,
              "$Comment": "Loops through each point stored in TaskComponent and sets leash target so seek can navigate there",
              "Sensor": {
                "Type": "LeashTarget"
              },
              "BodyMotion": {
                "Type": "Seek",
                "SlowDownDistance": 1,
                "StopDistance": 0.1,
                "RelativeSpeed": 0.55
              }
            },
            {
              "Sensor": {
                "$Comment": "If not leashing target, then switch to action state",
                "Type": "Not",
                "Sensor": {
                  "Type": "LeashTarget"
                }
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Action"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "Action state - Complete an action for a given location",
          "Sensor": {
            "Type": "State",
            "State": "Action"
          },
          "Instructions": [
            {
              "$Comment": "Play Idle Animation while waiting to run action",
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Idle",
                  "Once": true
                }
              ]
            },
            {
              "$Comment": "Sense nearby containers and run the action if the Task's Action is equal to 'DEPOSIT'",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Switch",
                    "Switch": { "Compute": "CanDoDeposit" }
                  },
                  {
                    "Type": "CanDoAction",
                    "Action": "Deposit"
                  }
                ]
              },
              "ActionsBlocking": true,
              "Actions": [
                {
                  "Type": "SetFlag",
                  "Name": "HoldingItem",
                  "SetTo": false
                },
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Deposit",
                  "Once": true
                },
                {
                  "Type": "Timeout",
                  "Delay": [ 0.4, 0.4 ]
                },
                {
                  "Type": "Deposit"
                },
                {
                  "Type": "Timeout",
                  "Delay": [ 0.4, 0.4 ]
                },
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": ""
                }
              ]
            },
            {
              "$Comment": "Sense nearby containers and run the action if the Task's Action is equal to 'TAKE'",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Switch",
                    "Switch": { "Compute": "CanDoTake" }
                  },
                  {
                    "Type": "CanDoAction",
                    "Action": "Take"
                  }
                ]
              },
              "ActionsBlocking": true,
              "Actions": [
                {
                  "Type": "SetFlag",
                  "Name": "HoldingItem",
                  "SetTo": true
                },
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Take",
                  "Once": true
                },
                {
                  "Type": "Timeout",
                  "Delay": [ 0.4, 0.4 ]
                },
                {
                  "Type": "Take"
                },
                {
                  "Type": "Timeout",
                  "Delay": [ 0.4, 0.4 ]
                },
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": ""
                }
              ]
            },
            {
              "$Comment": "Mark the action as done without doing anything if the Task's Action is equal to 'POSITION'",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Switch",
                    "Switch": { "Compute": "CanDoPosition" }
                  },
                  {
                    "Type": "CanDoAction",
                    "Action": "Position"
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "Position"
                }
              ]
            },
            {
              "$Comment": "Sense nearby locations and run the action if the Task's Action is equal to 'WORK'",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Switch",
                    "Switch": { "Compute": "CanDoWork" }
                  },
                  {
                    "Type": "CanDoAction",
                    "Action": "Work"
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "Work"
                }
              ]
            },
            {
              "$Comment": "Switch to Pathing state when there is NOT an action for the current target location",
              "Sensor": {
                "Type": "LeashTarget"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status"
                },
                {
                  "Type": "State",
                  "State": "Path"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Instructions": [
          {
            "Sensor": {
              "Type": "Or",
              "Sensors": [
                {
                  "Type": "And",
                  "Sensors": [
                    {
                      "Type": "Not",
                      "Sensor": {
                        "Type": "Player",
                        "Range": { "Compute": "ViewRange" },
                        "Filters": [
                          {
                            "Type": "ItemInHand",
                            "Items": [ "Tool_Brush" ]
                          }
                        ]
                      }
                    },
                    {
                      "Type": "Not",
                      "Sensor": {
                        "Type": "State",
                        "State": "Path"
                      }
                    }
                  ]
                },
                {
                  "Type": "Not",
                  "Sensor": {
                    "Type": "CanInteract",
                    "ViewSector": 360
                  }
                }
              ]
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Interactable": false
              }
            ]
          },
          {
            "Continue": true,
            "Sensor": {
              "$Comment": "Switch to Alerted if player has Brush",
              "Type": "Or",
              "Sensors": [
                {
                  "$Comment": "Set Interactable to true when Item in Hand is Brush",
                  "Type": "Player",
                  "Range": { "Compute": "ViewRange" },
                  "Filters": [
                    {
                      "Type": "ItemInHand",
                      "Items": [ "Tool_Brush" ]
                    }
                  ]
                },
                {
                  "$Comment": "Set Interactable to true when in Path state",
                  "Type": "State",
                  "State": "Path"
                }
              ]
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Interactable": true,
                "Hint": "server.interactionHints.command"
              }
            ]
          },
          {
            "Sensor": {
              "$Comment": "TODO: When Interacting, Play Particle Effects, Change Attachment to match State",
              "Type": "And",
              "Sensors": [
                {
                  "Type": "Player",
                  "Range": { "Compute": "ViewRange" },
                  "Filters": [
                    {
                      "Type": "ItemInHand",
                      "Items": [ "Tool_Brush" ]
                    }
                  ]
                },
                {
                  "Type": "HasInteracted"
                },
                {
                  "Type": "Not",
                  "Sensor": {
                    "Type": "State",
                    "State": "Path"
                  }
                }
              ]
            },
            "Actions": [
              {
                "Type": "LockOnInteractionTarget"
              },
              {
                "Type": "State",
                "State": "$Interaction"
              },
              {
                "$Comment": "Temporarily disable interactable",
                "Type": "SetInteractable",
                "Interactable": false
              },
              {
                "Type": "SetPath"
              }
            ]
          },
          {
            "Sensor": {
              "$Comment": "When interacting in the Path state, switch to Idle",
              "Type": "And",
              "Sensors": [
                {
                  "Type": "HasInteracted"
                },
                {
                  "Type": "State",
                  "State": "Path"
                }
              ]
            },
            "Actions": [
              {
                "Type": "State",
                "State": "Idle"
              },
              {
                "Type": "SetInteractable",
                "Interactable": false
              }
            ]
          }
        ]
      }
    ]
  },
  "NameTranslationKey": { "Compute": "NameTranslationKey" },
  "DeathInstruction": {
    "$Comment": "Drop inventory on death",
    "Sensor": {
      "Type": "Any"
    },
    "Actions": [
      {
        "Type": "DropInventory",
        "Once": true
      }
    ]
  },
  "Debug": "Flock"
}
