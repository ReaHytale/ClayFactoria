{
  "Type": "Abstract",
  "StartState": "Idle",
  "Parameters": {
    "Appearance": {
      "Value": "Trork_Clay",
      "Description": "Model to be used"
    },
    "ViewRange": {
      "Value": 15,
      "Description": "View range"
    },
    "DropList": {
      "Value": "Empty",
      "Description": "Drop Items"
    },
    "MaxSpeed": {
      "Value": 3,
      "Description": "Maximum walking speed"
    },
    "MaxHealth": {
      "Value": 100,
      "Description": "Max health for the NPC"
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Template.name",
      "Description": "Translation key for NPC name display"
    },
    "CanDoTake": {
      "Description": "Whether this automaton can perform the TAKE Task",
      "TypeHint": "Boolean",
      "Value": false
    },
    "CanDoDeposit": {
      "Description": "Whether this automaton can perform the DEPOSIT Task",
      "TypeHint": "Boolean",
      "Value": false
    },
    "CanDoPosition": {
      "Description": "Whether this automaton can perform the POSITION Task",
      "TypeHint": "Boolean",
      "Value": true
    },
    "CanDoWork": {
      "Description": "Whether this automaton can perform the WORK Task",
      "TypeHint": "Boolean",
      "Value": false
    },
    "CanDoHarvest": {
      "Description": "Whether this automaton can perform the HARVEST Task",
      "TypeHint": "Boolean",
      "Value": false
    },
    "HotbarItems": {
      "Description": "Hotbar Items (e.g. primary weapon, secondary weapon, etc)",
      "TypeHint": "String",
      "Value": [ ]
    },
    "CanSetFilterItem": {
      "Description": "Whether you can set a filter item on this automaton.",
      "TypeHint": "String",
      "Value": false
    }
  },
  "Appearance": { "Compute": "Appearance" },
  "DropList": { "Compute": "DropList" },
  "DisableDamageGroups": [ "Self" ],
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Neutral",
  "KnockbackScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": { "Compute": "MaxSpeed" },
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10,
      "MaxWalkTurnAngle": 180
    }
  ],
  "MaxHealth": { "Compute": "MaxHealth" },
  "CombatConfig": {
    "EntityEffect": "Immunity_Environmental"
  },
  "StateTransitions": [
    {
      "$Comment": "Always clear target and reset instructions when going back to idle.",
      "States": [
        {
          "To": [ "Idle" ],
          "From": [ ]
        }
      ],
      "Actions": [
        {
          "Type": "ReleaseTarget"
        },
        {
          "Type": "ResetInstructions"
        },
        {
          "Type": "PlayAnimation",
          "Slot": "Status"
        },
        {
          "Type": "DropInventory",
          "DropHotbarItems": false
        },
        {
          "Type": "ClearJobs"
        },
        {
          "Type": "SetFlag",
          "Name": "HoldingItem",
          "SetTo": false
        }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "Pathing, run all the time regardless of other instructions",
      "Continue": true,
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "And",
            "Sensors": [
              {
                "Type": "FlockLeader"
              },
              {
                "Type": "Self",
                "Filters": [
                  {
                    "Type": "Flock",
                    "FlockStatus": "Follower"
                  }
                ]
              }
            ]
          },
          "Actions": [
            {
              "Type": "Timeout",
              "Delay": [ 0.5, 2 ],
              "Action": {
                "Type": "SetLeashPosition",
                "ToTarget": true
              }
            }
          ]
        },
        {
          "$Comment": "Play Hold animation if holding an item right now",
          "Continue": true,
          "Sensor": {
            "Type": "Flag",
            "Name": "HoldingItem",
            "Set": true
          },
          "Actions": [
            {
              "Type": "PlayAnimation",
              "Slot": "Status",
              "Animation": "Hold",
              "Once": true
            }
          ]
        }
      ]
    },
    {
      "Instructions": [
        {
          "$Comment": "\"Look at me Hector.\"",
          "Continue": true,
          "Sensor": {
            "Type": "And",
            "Sensors": [
              {
                "Type": "Or",
                "Sensors": [
                  {
                    "Type": "State",
                    "State": "Idle.Alerted"
                  },
                  {
                    "Type": "State",
                    "State": "Programming"
                  }
                ]
              },
              {
                "Type": "Player",
                "Range": 10,
                "Filters": [
                  {
                    "Type": "ItemInHand",
                    "Items": [ "Tool_Brush" ]
                  }
                ]
              }
            ]
          },
          "BodyMotion": {
            "Type": "MaintainDistance",
            "DesiredDistanceRange": { "Compute": "makeRange(randomInRange(0.5,2.5))" },
            "MoveThreshold": { "Compute": "randomInRange(0.1,1)" },
            "MoveTowardsSlowdownThreshold": { "Compute": "randomInRange(1,3)" },
            "RelativeBackwardsSpeed": 0.5,
            "RelativeForwardsSpeed": 1,
            "TargetDistanceFactor": { "Compute": "randomInRange(0.1,1)" }
          },
          "HeadMotion": {
            "Type": "Watch",
            "RelativeTurnSpeed": { "Compute": "random()" }
          }
        },
        {
          "$Comment": "Await player instruction",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Player nearby with brush in hand",
              "Sensor": {
                "$Comment": "Play Alerted Particle Effect. Look at player. Await Interaction. Timeout after 15, seconds",
                "Type": "State",
                "State": ".Alerted"
              },
              "Instructions": [
                {
                  "$Comment": "Change back to idle once there is no longer a player in range",
                  "Sensor": {
                    "Type": "Not",
                    "Sensor": {
                      "$Comment": "Return to idle when item in hand is not brush",
                      "Type": "Player",
                      "Range": 10,
                      "Filters": [
                        {
                          "Type": "ItemInHand",
                          "Items": [ "Tool_Brush" ]
                        }
                      ]
                    }
                  },
                  "Actions": [
                    {
                      "Type": "State",
                      "State": "Idle",
                      "ClearState": true
                    }
                  ]
                },
                {
                  "Sensor": {
                    "Type": "Any",
                    "Once": false
                  },
                  "Actions": [
                    {
                      "Type": "Timeout",
                      "Delay": [ 0, 0.5 ],
                      "Action": {
                        "Type": "PlayAnimation",
                        "Slot": "Status",
                        "Animation": "Alerted",
                        "Once": false
                      }
                    },
                    {
                      "Type": "SpawnParticles",
                      "Offset": [ 0, 1, 0 ],
                      "ParticleSystem": "Alerted",
                      "Once": true
                    }
                  ]
                }
              ]
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Idle"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "HasAnyJobs"
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Automated"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Player",
                "Range": 10,
                "Filters": [
                  {
                    "Type": "ItemInHand",
                    "Items": [ "Tool_Brush" ]
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": ".Alerted"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "Automaton is performing Tasks automatically",
          "Sensor": {
            "Type": "State",
            "State": "Automated"
          },
          "Instructions": [
            {
              "Instructions": [
                {
                  "$Comment": "Return to Idle if there are no jobs",
                  "Sensor": {
                    "Type": "Not",
                    "Sensor": {
                      "Type": "HasAnyJobs"
                    }
                  },
                  "Actions": [
                    {
                      "Type": "State",
                      "State": "Idle"
                    }
                  ]
                },
                {
                  "$Comment": "Pathing state - Path to a single point or line path",
                  "Sensor": {
                    "Type": "State",
                    "State": ".Default"
                  },
                  "Instructions": [
                    {
                      "Continue": true,
                      "$Comment": "Loops through each point stored in JobComponent and sets leash target so seek can navigate there",
                      "Sensor": {
                        "Type": "LeashTarget"
                      },
                      "BodyMotion": {
                        "Type": "Seek",
                        "SlowDownDistance": 1,
                        "StopDistance": 0.1,
                        "RelativeSpeed": 0.55
                      }
                    },
                    {
                      "Sensor": {
                        "$Comment": "If not leashing target, then switch to Task state",
                        "Type": "Not",
                        "Sensor": {
                          "Type": "LeashTarget"
                        }
                      },
                      "Actions": [
                        {
                          "Type": "State",
                          "State": "Automated.Task"
                        }
                      ]
                    }
                  ]
                },
                {
                  "$Comment": "Task state - Complete an Task for a given location",
                  "Sensor": {
                    "Type": "State",
                    "State": ".Task"
                  },
                  "Instructions": [
                    {
                      "Continue": true,
                      "Sensor": {
                        "Type": "JobPosition"
                      },
                      "HeadMotion": {
                        "Type": "Watch"
                      }
                    },
                    {
                      "$Comment": "If there is a task that can be completed at this position, do it.",
                      "Reference": "Component_Instruction_Task",
                      "Modify": {
                        "CanDoWork": { "Compute": "CanDoWork" },
                        "CanDoTake": { "Compute": "CanDoTake" },
                        "CanDoDeposit": { "Compute": "CanDoDeposit" },
                        "CanDoPosition": { "Compute": "CanDoPosition" },
                        "CanDoHarvest": { "Compute": "CanDoHarvest" }
                      }
                    },
                    {
                      "$Comment": "Switch to default (pathing) state when there is NOT a Task for the current target location",
                      "Sensor": {
                        "Type": "LeashTarget"
                      },
                      "Actions": [
                        {
                          "Type": "PlayAnimation",
                          "Slot": "Status"
                        },
                        {
                          "Type": "State",
                          "State": "Automated.Default"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "$Comment": "Interactable when holding brush",
        "Sensor": {
          "Type": "Player",
          "Range": { "Compute": "ViewRange" },
          "Filters": [
            {
              "Type": "ItemInHand",
              "Items": [ "Tool_Brush" ]
            }
          ]
        },
        "Instructions": [
          {
            "Instructions": [
              {
                "$Comment": "Show \"Command\" as interaction hint while alerted",
                "Continue": true,
                "Sensor": {
                  "Type": "State",
                  "State": "Idle"
                },
                "Actions": [
                  {
                    "Type": "SetInteractable",
                    "Hint": "server.interactionHints.begin_command"
                  },
                  {
                    "Type": "State",
                    "State": "Idle.Alerted",
                    "Once": true,
                    "ClearState": false
                  }
                ]
              },
              {
                "$Comment": "Show \"Finish Command\" as interaction hint while programming",
                "Continue": true,
                "Sensor": {
                  "Type": "State",
                  "State": "Programming"
                },
                "Actions": [
                  {
                    "Type": "SetInteractable",
                    "Hint": "server.interactionHints.finish_command"
                  }
                ]
              },
              {
                "$Comment": "Show \"Stop\" as interaction hint while automating",
                "Continue": true,
                "Sensor": {
                  "Type": "State",
                  "State": "Automated"
                },
                "Actions": [
                  {
                    "Type": "SetInteractable",
                    "Hint": "server.interactionHints.stop_command"
                  }
                ]
              },
              {
                "$Comment": "Handle interaction behaviour",
                "Sensor": {
                  "Type": "HasInteracted"
                },
                "Instructions": [
                  {
                    "Instructions": [
                      {
                        "$Comment": "Stop automation",
                        "Sensor": {
                          "Type": "State",
                          "State": "Automated"
                        },
                        "Actions": [
                          {
                            "Type": "State",
                            "State": "Idle"
                          },
                          {
                            "Type": "SetInteractable",
                            "Hint": "server.interactionHints.begin_command"
                          }
                        ]
                      },
                      {
                        "$Comment": "Finish programming and start automation",
                        "Sensor": {
                          "Type": "State",
                          "State": "Programming"
                        },
                        "Actions": [
                          {
                            "Type": "SetPath"
                          },
                          {
                            "Type": "State",
                            "State": "Automated"
                          }
                        ]
                      },
                      {
                        "$Comment": "Start programming",
                        "Sensor": {
                          "Type": "State",
                          "State": "Idle"
                        },
                        "Actions": [
                          {
                            "Type": "State",
                            "State": "Programming"
                          },
                          {
                            "Type": "StartProgramming"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "$Comment": "Allow setting filter items when applicable",
        "Sensor": {
          "Type": "Switch",
          "Switch": { "Compute": "CanSetFilterItem" }
        },
        "Instructions": [
          {
            "$Comment": "Tooltip: \"Set Filter Item\"",
            "Sensor": {
              "Type": "Player",
              "Range": 10,
              "Filters": [
                {
                  "Type": "ItemInHand",
                  "Items": [ "EMPTY ITEM HERE?" ]
                }
              ]
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Enabled": true,
                "Hint": "server.interactionHints.set_filter"
              }
            ]
          },
          {
            "$Comment": "Tooltip: \"Clear Filter Item\"",
            "Sensor": {
              "Type": "Any"
            },
            "Actions": [
              {
                "Type": "SetInteractable",
                "Enabled": true,
                "Hint": "server.interactionHints.clear_filter"
              }
            ]
          }
        ]
      },
      {
        "$Comment": "Not interactable when not holding brush",
        "Sensor": {
          "Type": "Not",
          "Sensor": {
            "Type": "Player",
            "Range": { "Compute": "ViewRange" },
            "Filters": [
              {
                "Type": "ItemInHand",
                "Items": [ "Tool_Brush" ]
              }
            ]
          }
        },
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": false
          }
        ]
      },
      { }
    ]
  },
  "NameTranslationKey": { "Compute": "NameTranslationKey" },
  "DeathInstruction": {
    "$Comment": "Drop inventory on death",
    "Sensor": {
      "Type": "Any"
    },
    "Actions": [
      {
        "Type": "DropInventory",
        "Once": true,
        "DropHotbarItems": false
      }
    ]
  },
  "Debug": "",
  "DeathAnimationTime": 0.1,
  "HotbarItems": { "Compute": "HotbarItems" },
  "InventorySize": 9
}
