@Slice6ButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "ImageAssets/CommandWheelSlice6_Default.png"), LabelStyle: @SliceButtonLabelStyle),
  Hovered: (Background: (TexturePath: "ImageAssets/CommandWheelSlice6_Hover.png"), LabelStyle: @SliceButtonLabelStyle),
