      Style: @Slice5ButtonStyle;
      Text: "";
      Visible: false;
    }

    TextButton #CommandButton6 {
      Anchor: (Top: 312, Left: 161, Width: 142, Height: 217);
      Style: @Slice6ButtonStyle;
      Text: "";
      Visible: false;
    }

    TextButton #CommandButton7 {
      Anchor: (Top: 147, Left: 187, Width: 207, Height: 207);
      Style: @Slice7ButtonStyle;
      Text: "";
      Visible: false;
    }

    Label #CommandLabel0 {
      Anchor: (Top: 164, Left: 376, Width: 168, Height: 44);
      Text: "";
      Style: @SliceLabelStyle;
      Visible: false;
    }

    Label #CommandLabel1 {
      Anchor: (Top: 233, Left: 541, Width: 170, Height: 44);
