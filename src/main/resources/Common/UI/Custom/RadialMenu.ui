  Disabled: (Background: (TexturePath: "ImageAssets/CommandWheelSlice6_Default.png", Color: #ffffff(0.5)), LabelStyle: @SliceButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
);

@Slice7ButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "ImageAssets/CommandWheelSlice7_Default.png"), LabelStyle: @SliceButtonLabelStyle),
  Hovered: (Background: (TexturePath: "ImageAssets/CommandWheelSlice7_Hover.png"), LabelStyle: @SliceButtonLabelStyle),
  Pressed: (Background: (TexturePath: "ImageAssets/CommandWheelSlice7_Pressed.png"), LabelStyle: @SliceButtonLabelStyle),
  Disabled: (Background: (TexturePath: "ImageAssets/CommandWheelSlice7_Default.png", Color: #ffffff(0.5)), LabelStyle: @SliceButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
