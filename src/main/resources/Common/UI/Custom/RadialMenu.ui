$C = "Common.ui";

@SliceLabelStyle = LabelStyle(
  FontSize: 15,
  RenderBold: true,
  TextColor: #d6e0ec,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  OutlineColor: #000000(0.7),
  Wrap: true,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 11
);

@SliceButtonLabelStyle = LabelStyle(
  FontSize: 14,
  RenderBold: true,
  RenderUppercase: true,
  TextColor: #00000000,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@SliceButtonDisabledLabelStyle = LabelStyle(
  ...@SliceButtonLabelStyle
);

@Slice0ButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "ImageAssets/4Radial0_Default.png"), LabelStyle: @SliceButtonLabelStyle),
  Hovered: (Background: (TexturePath: "ImageAssets/4Radial0_Hover.png"), LabelStyle: @SliceButtonLabelStyle),
  Pressed: (Background: (TexturePath: "ImageAssets/4Radial0_Click.png"), LabelStyle: @SliceButtonLabelStyle),
  Disabled: (Background: (TexturePath: "ImageAssets/4Radial0_Default.png", Color: #ffffff(0.5)), LabelStyle: @SliceButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
);

@Slice1ButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "ImageAssets/4Radial1_Default.png"), LabelStyle: @SliceButtonLabelStyle),
  Hovered: (Background: (TexturePath: "ImageAssets/4Radial1_Hover.png"), LabelStyle: @SliceButtonLabelStyle),
  Pressed: (Background: (TexturePath: "ImageAssets/4Radial1_Click.png"), LabelStyle: @SliceButtonLabelStyle),
  Disabled: (Background: (TexturePath: "ImageAssets/4Radial1_Default.png", Color: #ffffff(0.5)), LabelStyle: @SliceButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
);

@Slice2ButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "ImageAssets/4Radial2_Default.png"), LabelStyle: @SliceButtonLabelStyle),
  Hovered: (Background: (TexturePath: "ImageAssets/4Radial2_Hover.png"), LabelStyle: @SliceButtonLabelStyle),
  Pressed: (Background: (TexturePath: "ImageAssets/4Radial2_Click.png"), LabelStyle: @SliceButtonLabelStyle),
  Disabled: (Background: (TexturePath: "ImageAssets/4Radial2_Default.png", Color: #ffffff(0.5)), LabelStyle: @SliceButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
);

@Slice3ButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "ImageAssets/4Radial3_Default.png"), LabelStyle: @SliceButtonLabelStyle),
  Hovered: (Background: (TexturePath: "ImageAssets/4Radial3_Hover.png"), LabelStyle: @SliceButtonLabelStyle),
  Pressed: (Background: (TexturePath: "ImageAssets/4Radial3_Click.png"), LabelStyle: @SliceButtonLabelStyle),
  Disabled: (Background: (TexturePath: "ImageAssets/4Radial3_Default.png", Color: #ffffff(0.5)), LabelStyle: @SliceButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
);

$C.@PageOverlay {
  LayoutMode: Middle;

  Group #CommandMenuWheel {
    Anchor: (Width: 920, Height: 760);
    Visible: false;

    Label #CommandMenuTitle {
      Anchor: (Top: 18, Width: 620, Height: 42, Left: 150);
      Text: "";
      Style: (
        FontSize: 38,
        RenderBold: true,
        TextColor: #ffffff,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
    }

    Label #CommandMenuSubtitle {
      Anchor: (Top: 62, Width: 620, Height: 26, Left: 150);
      Text: "";
      Style: (
        FontSize: 16,
        TextColor: #dbe4e7,
        HorizontalAlignment: Center,
        VerticalAlignment: Center
      );
    }

    Group #CommandWheelCenterPanel {
      Anchor: (Width: 227, Height: 227);
      Background: (TexturePath: "ImageAssets/RadialCentre.png");
    }

    Label #CommandMenuCurrent {
      Anchor: (Width: 227, Height: 130);
      Text: "";
      Style: (
        FontSize: 22,
        RenderBold: true,
        TextColor: #ffffff,
        HorizontalAlignment: Center,
        VerticalAlignment: Center,
        Wrap: true,
        OutlineColor: #000000(0.7)
      );
    }

    Group #CommandButton0Group {
      Anchor: (Top: 128, Left: 460, Width: 252, Height: 252);
      TextButton #CommandButton0 {
        Anchor: (Top: 0, Left: 0, Width: 252, Height: 252);
        Text: "";
        Style: @Slice0ButtonStyle;
        Visible: false;
      }
      Panel #CommandButton0Icon {
        Anchor: (Top: 80, Left: 80, Width: 80, Height: 80);
        Background: (TexturePath: "ImageAssets/Take.png");
      }
    }

    Group #CommandButton1Group {
      Anchor: (Top: 380, Left: 460, Width: 252, Height: 252);
      TextButton #CommandButton1 {
        Anchor: (Top: 0, Left: 0, Width: 252, Height: 252);
        Text: "";
        Style: @Slice1ButtonStyle;
        Visible: false;
      }
      Panel #CommandButton1Icon {
        Anchor: (Top: 80, Left: 80, Width: 80, Height: 80);
        Background: (TexturePath: "ImageAssets/Deposit.png");
      }
    }

    Group #CommandButton2Group {
      Anchor: (Top: 380, Left: 208, Width: 252, Height: 252);
      TextButton #CommandButton2 {
        Anchor: (Top: 0, Left: 0, Width: 252, Height: 252);
        Text: "";
        Style: @Slice2ButtonStyle;
        Visible: false;
      }
      Panel #CommandButton2Icon {
        Anchor: (Top: 80, Left: 80, Width: 80, Height: 80);
        Background: (TexturePath: "ImageAssets/Work.png");
      }
    }

    Group #CommandButton3Group {
      Anchor: (Top: 128, Left: 208, Width: 252, Height: 252);
      TextButton #CommandButton3 {
        Anchor: (Top: 0, Left: 0, Width: 252, Height: 252);
        Text: "";
        Style: @Slice3ButtonStyle;
        Visible: false;
      }
      Panel #CommandButton3Icon {
        Anchor: (Top: 80, Left: 80, Width: 80, Height: 80);
        Background: (TexturePath: "ImageAssets/Position.png");
      }
    }
  }
}
