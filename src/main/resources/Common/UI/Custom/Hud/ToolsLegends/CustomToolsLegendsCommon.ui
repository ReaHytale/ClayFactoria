@Row = Group {
  LayoutMode: CenterMiddle;
  Anchor: (Vertical: 4);
};

@RowHintContainer = Group {
  LayoutMode: MiddleCenter;
  Padding: (Horizontal: 6, Vertical: 8);
  Anchor: (MinWidth: 48, Right: 10);
  Background: (TexturePath: "../../Common/InputBinding.png", Border: 6);
};

@RowHintTextStyle = LabelStyle(
  RenderBold: true,
  RenderUppercase: true,
  FontName: "Secondary",
  FontSize: 14,
  TextColor: #ffffff(0.8),
  OutlineColor: #000000(0)
);

@RowHintText = Label {
  Style: @RowHintTextStyle;
};

@RowLabelContainer = Group {
  FlexWeight: 1;
  LayoutMode: Middle;
  Anchor: (Top: 0);
};

@RowLabel = Label {
  Style: (
    FontSize: 14,
    TextColor: #96a9be,
    Wrap: true
  );
};

@RowLabelCenter = Label {
  Style: (
    Alignment: Center,
    FontSize: 14,
    TextColor: #96a9be,
    Wrap: true
  );
};

@RowHintIconSize = 24;

@RowHintIconMouseLeftClick = PatchStyle(TexturePath: "../../Common/SmallInputIconMouseLeftClick.png");
@RowHintIconMouseMiddleClick = PatchStyle(TexturePath: "../../Common/SmallInputIconMouseMiddleClick.png");
@RowHintIconMouseRightClick = PatchStyle(TexturePath: "../../Common/SmallInputIconMouseRightClick.png");
@RowHintIconKeyUp = PatchStyle(TexturePath: "../../Common/InputIconKeyUp_White.png", Color: #ffffff(0.8));
@RowHintIconKeyRight = PatchStyle(TexturePath: "../../Common/InputIconKeyRight_White.png", Color: #ffffff(0.8));
@RowHintIconKeyDown = PatchStyle(TexturePath: "../../Common/InputIconKeyDown_White.png", Color: #ffffff(0.8));
@RowHintIconKeyLeft = PatchStyle(TexturePath: "../../Common/InputIconKeyLeft_White.png", Color: #ffffff(0.8));
@IconBrushMask = PatchStyle(TexturePath: "../../Common/IconMaskSettings.png", Color: #ffffff);

@Separator = Group {
  Anchor: (Height: 2, Vertical: 10);
  Background: #ffffff(0.15);
};

@SectionHeader = Label {
  Style: (
    FontSize: 15,
    TextColor: #ffffff(0.95),
    Wrap: false
  );
  Padding: (Top: 10, Bottom: 0);
};

@Legend = Group {
  Background: (TexturePath: "LegendContainerPanelPatch.png", Border: 4);
  LayoutMode: Top;
  Anchor: (Left: 20, Top: 110, Width: 300, Height: 800);
  Padding: (Full: 14);
  Visible: true;

  Group {
    Anchor: (Bottom: 10);

    Label #Title {
      Style: (
        Alignment: Center,
        FontSize: 16,
        RenderBold: true,
        RenderUppercase: true
      );
      Text: %client.builderTools.legend.title;
    }

    Group {
      FlexWeight: 1;
    }

  }

  Group #Pages {}

  Group {
    FlexWeight: 1;
  }
};

@Page = Group {
  @Title = "";
  LayoutMode: Top;

  Label #Subtitle {
    Style: (
      Alignment: Center,
      FontSize: 16,
      RenderBold: false,
      RenderUppercase: false
    );
    Text: @Title;
  }
};

@TitledRow = Group {
  @Name = "";
  @Description = "";
  @Spacing = 0;

  LayoutMode: Top;

  Label {
    Style: (
      FontSize: 14,
      TextColor: #ffffff(0.8),
      RenderBold: true,
      Wrap: true
    );
    Padding: (Top: 2);
    Text: @Name;
  }

  Label {
    Style: (
      FontSize: 14,
      TextColor: #96a9be,
      Wrap: true
    );
    Padding: (Top: @Spacing, Bottom: 4);
    Text: @Description;
  }
};

@IconRow = Group {
  @Icon = "";
  @Description = "";
  @LayoutMode = Middle;

  @Row {
    @RowHintContainer {
      LayoutMode: CenterMiddle;

      Group {
        Anchor: (Width: @RowHintIconSize, Height: @RowHintIconSize);
        Background: @Icon;
      }
    }

    @RowLabelContainer {
      LayoutMode: @LayoutMode;
      @RowLabel {
        Text: @Description;
      }
    }
  }
};